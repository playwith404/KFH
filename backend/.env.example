APP_PORT=8700
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://khp_app:CHANGE_ME@DB_HOST:5432/khp
JWT_SECRET=CHANGE_ME
CORS_ALLOW_ORIGINS=http://localhost:3700,https://kph.pjcloud.store

# Redis (optional)
REDIS_URL=redis://host.docker.internal:10700/0

# Demo identity verification
DEMO_IDENTITY_VERIFICATION=true
DEMO_IDENTITY_CODE=000000

# Demo convenience (auto create tables + seed on startup)
APP_AUTO_INIT=false
